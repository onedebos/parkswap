# =============================================================================
# ParkSwap / dex-ui — copy to `.env.local` and adjust. Values are examples only.
# =============================================================================

# --- Optional: canonical site origin (no trailing slash) ---
# Used as Next.js `metadataBase` for Open Graph / Twitter card absolute URLs.
# Local dev defaults to http://localhost:3000. On Vercel, `VERCEL_URL` is used
# if this is unset — you do not need to set VERCEL_URL yourself.
# NEXT_PUBLIC_SITE_URL=https://your-deployment.example.com

# --- Optional: Blockscout (or compatible) explorer API origin (no trailing slash) ---
# Transaction and address links use {base}/tx/{hash} and {base}/address/{address}.
NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://demo-blockscout.txpark.nomadic-labs.com

# --- Optional: extra featured swap token (VNXAU) on Tezos X EVM testnet ---
# When set to a valid ERC-20 address, VNXAU appears in Trade “Featured” token list.
# NEXT_PUBLIC_VNXAU_TOKEN_ADDRESS=0x...
